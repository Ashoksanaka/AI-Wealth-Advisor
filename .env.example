# App environment (Vercel / managed Postgres)
NODE_ENV=production

# PostgreSQL — use pooled URL for DATABASE_URL (Neon -pooler, Supabase transaction pooler)
DATABASE_URL=
DIRECT_URL=

# Clerk — set in Vercel before first deploy (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# NVIDIA NIM — https://build.nvidia.com → Settings → API Keys
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct
# NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1

# Resend — https://resend.com/api-keys (use verified domain in production)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Arcjet — https://app.arcjet.com
ARCJET_KEY=
ARCJET_ENV=production

# Inngest Cloud — https://app.inngest.com (do not set INNGEST_DEV in production)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Optional: enable demo seed on production deploy (default: disabled)
# ALLOW_DEMO_SEED=true

# Optional: IDBI sandbox adapter (production integration)
# IDBI_SANDBOX_API_URL=
