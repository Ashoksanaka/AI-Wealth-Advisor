# App environment
NODE_ENV=development

# PostgreSQL (Docker internal hostnames)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_wealth_management
DIRECT_URL=postgresql://postgres:postgres@postgres:5432/ai_wealth_management

# Clerk — https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# NVIDIA NIM — https://build.nvidia.com → Settings → API Keys
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Arcjet — https://app.arcjet.com
ARCJET_KEY=
ARCJET_ENV=development

# Inngest Dev Server (Docker compose only — omit for Inngest Cloud)
INNGEST_DEV=1
INNGEST_BASE_URL=http://inngest:8288
INNGEST_SERVE_HOST=http://app:3000

# Inngest Cloud (production / Vercel — use instead of INNGEST_DEV above)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
